{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pbmp.local/schemas/expected-output-contract.schema.json",
  "title": "PBMP Expected Output Contract",
  "type": "object",
  "required": [
    "expected_output_contract_id",
    "requirement_ids",
    "expected_business_outcome",
    "in_scope",
    "acceptance_criteria",
    "status"
  ],
  "properties": {
    "expected_output_contract_id": {
      "type": "string",
      "pattern": "^EOC-[A-Z0-9-]+$"
    },
    "source_stage": { "type": "string" },
    "business_goal_id": { "type": "string" },
    "requirement_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "expected_business_outcome": { "type": "string", "minLength": 10 },
    "in_scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "actors": { "type": "array", "items": { "type": "string" } },
    "data_entities": { "type": "array", "items": { "type": "string" } },
    "business_rules": { "type": "array", "items": { "type": "string" } },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "nfrs": { "type": "object", "additionalProperties": { "type": "string" } },
    "approved_by": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["Draft", "Approved for Design", "Approved for Development", "Released"]
    }
  }
}
