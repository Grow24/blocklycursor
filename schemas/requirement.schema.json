{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pbmp.local/schemas/requirement.schema.json",
  "title": "PBMP Requirement",
  "type": "object",
  "required": [
    "requirement_id",
    "goal",
    "actor",
    "trigger",
    "actions",
    "acceptance_criteria"
  ],
  "properties": {
    "requirement_id": {
      "type": "string",
      "pattern": "^REQ-[A-Z0-9-]+$"
    },
    "goal": { "type": "string", "minLength": 3 },
    "actor": { "type": "string", "minLength": 2 },
    "trigger": { "type": "string", "minLength": 3 },
    "condition": {
      "type": ["object", "null"],
      "properties": {
        "field": { "type": "string" },
        "operator": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "operator", "value"],
        "properties": {
          "field": { "type": "string" },
          "operator": { "type": "string" },
          "value": { "type": "string" }
        }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "data_entities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "business_rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 10 }
    },
    "nfrs": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "approvals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": {
      "type": "string",
      "enum": ["Draft", "Validated", "Approved for Design", "In Design", "In Development", "Released"]
    },
    "blockly_workspace": { "type": "object" }
  },
  "additionalProperties": true
}
