# Server
PORT=3000
NODE_ENV=development

# Zeabur sets PORT automatically in production — set a real number (e.g. 3000),
# never PORT=${WEB_PORT} (Zeabur may leave that as a literal string → 502).
# PBMP_DATA_DIR=./data/requirements
# PBMP_LMS_DATA_DIR=./data/lms
# PBMP_CURSOR_DATA_DIR=./data/cursor

# Cursor Cloud Agents API (for Call API button in dispatch modal)
# Generate key: Cursor Dashboard → API Keys (Cloud Agents)
# CURSOR_API_KEY=
# CURSOR_REPOSITORY=https://github.com/Grow24/blocklycursor
# CURSOR_REPO_REF=main
# CURSOR_AUTO_CREATE_PR=false
# CURSOR_AGENTS_API_URL=https://api.cursor.com/v1/agents
# CURSOR_WEB_CHAT_URL=https://www.cursor.com

# --- PBMP Cursor Token Governance (GAP-CURSOR-TOKEN-001) ---
# Cursor connection defaults
# CURSOR_MODEL_DEFAULT=auto
# CURSOR_ALLOWED_MODELS=auto,composer,gpt-5-mini

# Prompt size limits
# PBMP_MAX_PROMPT_TOKENS=8000
# PBMP_MAX_CONTEXT_TOKENS=50000
# PBMP_MAX_TOTAL_INPUT_TOKENS=75000
# PBMP_MAX_EXPECTED_OUTPUT_TOKENS=15000

# File/context limits
# PBMP_MAX_FILES_PER_CURSOR_RUN=20
# PBMP_MAX_FILE_BYTES_PER_RUN=300000
# PBMP_MAX_REPO_SCAN_FILES=100

# Cost estimation
# PBMP_COST_ESTIMATE_ENABLED=true
# PBMP_COST_BUFFER_MULTIPLIER=2.0
# PBMP_COST_WARNING_THRESHOLD_USD=0.25
# PBMP_COST_APPROVAL_THRESHOLD_USD=0.50
# PBMP_HARD_STOP_COST_USD=1.00

# User / trial limits
# PBMP_TRIAL_USER_DAILY_RUN_LIMIT=3
# PBMP_TRIAL_USER_MONTHLY_BUDGET_USD=0.50
# PBMP_PAID_USER_MONTHLY_BUDGET_USD=5.00
# PBMP_PROJECT_MONTHLY_BUDGET_USD=10.00

# Global Cursor wallet protection (shared Pro account)
# PBMP_CURSOR_MONTHLY_BUDGET_USD=20.00
# PBMP_CURSOR_OVERAGE_ALLOWED=false

# Rate limiting
# PBMP_CURSOR_RUNS_PER_USER_PER_DAY=5
# PBMP_CURSOR_RUNS_PER_PROJECT_PER_DAY=20
# PBMP_CURSOR_CONCURRENT_RUNS_LIMIT=2

# Safety / governance
# PBMP_REQUIRE_COST_CONFIRMATION=true
# PBMP_REQUIRE_ADMIN_APPROVAL_ABOVE_USD=0.50
# PBMP_REQUIRE_REPO_ALLOWLIST=true
# PBMP_ALLOWED_REPOS=Grow24/blocklycursor,Grow24/bpmpcursor

# Local identity defaults (until PBMP auth maps real users)
# PBMP_DEFAULT_CURSOR_USER_ID=local-dev-user
# PBMP_DEFAULT_CURSOR_USER_TIER=trial
# PBMP_DEFAULT_CURSOR_PROJECT_ID=pbmp-workbench
